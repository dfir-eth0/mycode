from scapy.all import *
import random
import time
import sys
from concurrent.futures import ThreadPoolExecutor, as_completed

conf.verb = 0


class IdleMaimonScanner:
    """
    Implements Maimon idle scanning technique.
    
    How it works:
    1. Get initial IP ID from zombie host (SYN packet)
    2. Send spoofed FIN packet to target (appearing from zombie)
    3. Get final IP ID from zombie host
    4. Analyze delta to infer port state:
       - delta == 2: target port OPEN (zombie sent RST, incrementing ID)
       - delta == 1: target port CLOSED (zombie sent RST? Actually no)
       - delta != 1/2: FILTERED or zombie unreliable
    
    Note: Real implementation would validate zombie suitability first.
    """
    
    def __init__(self, zombie_ip, zombie_port=80):
        self.zombie_ip = zombie_ip
        self.zombie_port = zombie_port
        
    def get_ip_id(self):
        """
        Retrieve current IP ID from zombie host.
        Returns None if zombie doesn't respond (dead or unreachable).
        """
        src_port = random.randint(1024, 65535)
        # SYN packet to probe zombie's IP ID counter
        ip_packet = IP(dst=self.zombie_ip)
        tcp_packet = TCP(
            sport=src_port, 
            dport=self.zombie_port, 
            flags="S",
            seq=random.randint(1, 100000)
        )
        
        response = sr1(ip_packet/tcp_packet, timeout=2, verbose=0)
        
        # Check for SYN-ACK response (flags=0x12)
        if response and response.haslayer(TCP) and response.getlayer(TCP).flags == 0x12:
            return response.getlayer(IP).id
        return None
    
    def maimon_probe(self, target_ip, target_port, spoof_ip):
        """
        Send FIN packet to target, spoofed from zombie IP.
        FIN (not SYN) is used for Maimon technique.
        """
        src_port = random.randint(1024, 65535)
        ip_packet = IP(dst=target_ip, src=spoof_ip)
        tcp_packet = TCP(
            sport=src_port, 
            dport=target_port, 
            flags="FA",  # FIN+ACK for Maimon
            seq=random.randint(1, 100000)
        )
        send(ip_packet/tcp_packet, verbose=0)
    
    def scan_port(self, target_ip, target_port):
        """
        Scan single port using Maimon idle technique.
        Returns: 'open', 'closed', 'filtered', or 'zombie_dead'
        """
        # Get baseline IP ID
        id_before = self.get_ip_id()
        if id_before is None:
            return "zombie_dead"
        
        # Send probe (appearing from zombie)
        self.maimon_probe(target_ip, target_port, self.zombie_ip)
        time.sleep(0.5)  # FIXME: Should be RTT-adaptive, not fixed delay
        
        # Get new IP ID
        id_after = self.get_ip_id()
        if id_after is None:
            return "zombie_dead"
        
        # Handle 16-bit overflow correctly
        delta = (id_after - id_before) & 0xFFFF
        
        # Interpret results
        if delta == 2:
            return "open"
        elif delta == 1:
            return "closed"
        else:
            # delta > 2 indicates either:
            # - Background traffic on zombie (false positive risk)
            # - Packet loss or filtering
            return "filtered"
    
    def scan_range_parallel(self, target_ip, ports, max_workers=5):
        """
        Scan multiple ports in parallel for better performance.
        Without this, scanning 100 ports would take ~100 seconds.
        
        Note: Parallel scanning increases detection risk but demonstrates
        understanding of concurrency.
        """
        results = {}
        
        with ThreadPoolExecutor(max_workers=max_workers) as executor:
            futures = {
                executor.submit(self.scan_port, target_ip, port): port 
                for port in ports
            }
            
            for future in as_completed(futures):
                port = futures[future]
                try:
                    status = future.result()
                    results[port] = status
                    print(f"[{port:5d}] {status}")
                except Exception as e:
                    results[port] = f"error: {e}"
                    print(f"[{port:5d}] error")
        
        return results
    
    def scan_range_sequential(self, target_ip, ports):
        """
        Sequential scan - simpler but slower.
        Kept for comparison/demonstration.
        """
        results = {}
        for port in ports:
            status = self.scan_port(target_ip, port)
            results[port] = status
            print(f"{target_ip}:{port} - {status}")
            time.sleep(1)
        return results



